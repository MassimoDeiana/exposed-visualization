<idea-plugin>
    <id>io.github.massimodeiana.exposed-er</id>
    <name>Exposed ER Diagram</name>
    <vendor>massimodeiana</vendor>
    <description>Generate ER diagrams from Kotlin Exposed table definitions. Live preview updates as you edit.</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Exposed ER Diagram"
                    anchor="right"
                    icon="/icons/erDiagram.svg"
                    factoryClass="io.github.massimodeiana.exposed.er.intellij.toolwindow.ErDiagramToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="ExposedEr.Generate"
                class="io.github.massimodeiana.exposed.er.intellij.actions.GenerateErDiagramAction"
                text="Generate Exposed ER Diagram"
                icon="/icons/erDiagram.svg"
                description="Generate ER diagram from Exposed table definitions">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
